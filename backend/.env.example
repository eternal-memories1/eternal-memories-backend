# ── Base de Datos ────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<usuario>:<password>@cluster0.xxxxx.mongodb.net/eternal-memories?retryWrites=true&w=majority

# ── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=una_clave_secreta_muy_larga_y_segura_aqui_2024
JWT_EXPIRES_IN=30d

# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# ── Google y Seguridad ───────────────────────────────────────────────────────
# Obtenido desde Google Cloud Console (Para Login con Google)
GOOGLE_CLIENT_ID=tu_cliente_id_google.apps.googleusercontent.com

# Obtenido desde Google Enterprise reCAPTCHA (v2 Checkbox)
RECAPTCHA_SECRET_KEY=tu_clave_secreta_recaptcha

# ── Pagos (Mercado Pago) ─────────────────────────────────────────────────────
# Obtenido desde el Dashboard de Integraciones de Mercado Pago -> Producción
# Debe empezar con APP_USR-...
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxx-xxxxxx
